# =============================================
# App Domande Ometec — Backend Environment
# =============================================
# Copia questo file in .env e compila i valori

# Porta del server (default: 3001)
PORT=3001

# URL del frontend (per CORS — lascia vuoto in produzione Vercel)
FRONTEND_URL=http://localhost:5173

# --- Vercel KV (Redis) ---
# Queste variabili vengono iniettate automaticamente da Vercel quando colleghi uno store KV
# In locale non servono — usa il file JSON automaticamente
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Database SQL Server (alternativa) ---
# Lascia vuoto per usare la modalità file JSON locale
DB_SERVER=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_CERT=true

# --- Login admin in modalità locale (solo se DB_SERVER è vuoto) ---
ADMIN_USER=admin
ADMIN_PASSWORD=admin

# --- JWT ---
# In modalità locale usa "dev-secret-locale" se non specificato
JWT_SECRET=cambia_questo_con_una_stringa_segreta_lunga
JWT_EXPIRES_IN=8h
